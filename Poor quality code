#include <stdio.h>

int square(int x)
{
    int result;
    result = x * x;
    return result;
}

int main()
{
    int num;
    printf("Enter a number: ");
    scanf("%d", &num);

    int result = square(num);

    printf("The square of %d is %d\n", num, result);

    return 0;
}
