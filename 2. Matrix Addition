#include <stdio.h>

#define MAX_ROWS 10
#define MAX_COLS 10


void inputMatrix(int rows, int cols, int matrix[MAX_ROWS][MAX_COLS]){
  int i,j;

  for(i=0; i<rows; i++){
   for(j=0; j<cols; j++){
      clrscr();
      printf("\nEnter Input for position %d x %d : ", i+1, j+1);
      scanf("%d", &matrix[i][j]);
   }
  }
}
void displayMatrix(int rows, int cols, int matrix[MAX_ROWS][MAX_COLS]){
 int i,j;
 for(i=0; i<rows; i++){
   for(j=0; j<cols; j++){
     printf("%d ", matrix[i][j]);
   }
   printf("\n");
 }
}

void additionMatrix(int rows, int cols ,int matrix1[MAX_ROWS][MAX_COLS],int matrix2[MAX_ROWS][MAX_COLS],int result[MAX_ROWS][MAX_COLS]){
 int i,j;

 for(i=0; i<rows; i++){
  for(j=0; j<cols; j++){
   result[i][j]=matrix1[i][j]+matrix2[i][j];
  }
 }
}


void main(){
 int rows, cols;
 int matrix1[MAX_ROWS][MAX_COLS], matrix2[MAX_ROWS][MAX_COLS], result[MAX_ROWS][MAX_COLS];
 clrscr();
 printf("Please enter order of square matrix:");
 scanf("%d", &cols);
 rows=cols;


 if(rows!=cols | rows>MAX_ROWS){
   printf("The Matrix Should be less than 10 order");
 }else{
 printf("You have Entered: %d rows and %d cols",rows, cols);
 printf("\n Enter input of Matrix1: ");
 inputMatrix(rows, cols, matrix1);
 printf("\n Enter input for Matrix2 : ");
 inputMatrix(rows, cols, matrix2);
 clrscr();
 printf("\nYou have entered Matrix1:\n");
 displayMatrix(rows, cols, matrix1);
 printf("\n You have entered Matrix2:\n ");
 displayMatrix(rows, cols, matrix2);

 additionMatrix(rows, cols, matrix1,matrix2, result);

 printf("\n Result Matrix:\n");
 displayMatrix(rows, cols, result);
 }



 getch();
}

