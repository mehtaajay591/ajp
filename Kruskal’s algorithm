import java.util.*;

public class KruskalsAlgorithm {

    public static void main(String[] args) {
        // Given graph as an adjacency matrix
        int[][] graph = {
                {0, 2, 4, 1, 0},
                {2, 0, 0, 3, 0},
                {4, 0, 0, 2, 5},
                {1, 3, 2, 0, 7},
                {0, 0, 5, 7, 0}
        };

        // Find the minimum cost spanning tree using Kruskal's algorithm
        List<Edge> mstEdges = kruskal(graph);

        // Show the processes
        printMCST(mstEdges);
    }

    // Edge class representing an edge in the graph
    static class Edge {
        int source;
        int destination;
        int weight;

        public Edge(int source, int destination, int weight) {
            this.source = source;
            this.destination = destination;
            this.weight = weight;
        }
    }

    // Kruskal's algorithm to find the minimum cost spanning tree
    static List<Edge> kruskal(int[][] graph) {
        int vertices = graph.length;
        List<Edge> edges = new ArrayList<>();

        // Populate the edges list with non-zero weighted edges
        for (int i = 0; i < vertices; i++) {
            for (int j = i + 1; j < vertices; j++) {
                if (graph[i][j] != 0) {
                    edges.add(new Edge(i, j, graph[i][j]));
                }
            }
        }

        // Sort edges in ascending order of weight
        edges.sort(Comparator.comparingInt(edge -> edge.weight));

        int[] parent = new int[vertices];
        Arrays.fill(parent, -1); // Initialize parent array

        List<Edge> mstEdges = new ArrayList<>();

        for (Edge edge : edges) {
            int root1 = find(parent, edge.source);
            int root2 = find(parent, edge.destination);

            // If including this edge does not cause a cycle, add it to the minimum cost spanning tree
            if (root1 != root2) {
                mstEdges.add(edge);
                union(parent, root1, root2);
            }
        }

        return mstEdges;
    }

    // Helper method to find the root of a set (with path compression)
    static int find(int[] parent, int i) {
        if (parent[i] == -1) {
            return i;
        }
        return find(parent, parent[i]);
    }

    // Helper method to perform union of two sets (with union by rank)
    static void union(int[] parent, int root1, int root2) {
        int xRoot = find(parent, root1);
        int yRoot = find(parent, root2);

        if (xRoot != yRoot) {
            parent[xRoot] = yRoot;
        }
    }

    // Helper method to print the Minimum Cost Spanning Tree (MCST)
    static void printMCST(List<Edge> mstEdges) {
        System.out.println("Minimum Cost Spanning Tree (MCST):");
        for (Edge edge : mstEdges) {
            char source = (char) ('A' + edge.source);
            char destination = (char) ('A' + edge.destination);
            int weight = edge.weight;
            System.out.println("Edge: " + source + " - " + destination + ", Weight: " + weight);
        }
    }
}

